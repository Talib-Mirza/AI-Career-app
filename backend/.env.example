# Application
APP_NAME="AI Career App"
APP_VERSION=2.0.0
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT used to verify browser access tokens (Authorization: Bearer …).
# In Dashboard: Project Settings → API → JWT (copy "JWT Secret" / legacy shared secret).
# Do NOT paste the anon or service_role keys here (those values start with eyJ and are JWTs, not the secret).
# If your project uses JWT Signing Keys (asymmetric), access tokens are RS256/ES256 and are verified via JWKS;
# you still need SUPABASE_URL; SUPABASE_JWT_SECRET is only required for HS256 tokens.
SUPABASE_JWT_SECRET=

# JWT
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# LLM API Keys (provider selected in backend/config.yaml)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# Supabase pgvector reuse
ROADMAP_MATCH_THRESHOLD=0.1
